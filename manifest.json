{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.2",
  "description": "Badge e widget con utilizzo sessione Claude.ai via API diretta",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["widget.js"],
      "run_at": "document_idle"
    }
  ]
}
